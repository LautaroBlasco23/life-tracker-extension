{
  "manifest_version": 3,
  "name": "Life Tracker — Screen Time",
  "version": "1.0",
  "description": "Tracks visits to configured websites.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://localhost:8080/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "Screen Time Tracker" }
}
